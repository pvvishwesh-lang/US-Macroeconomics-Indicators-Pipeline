    {
      "name": "085dc3ec",
      "displayName": "recession_predictions",
      "queryLines": [
        "SELECT *,case when \n",
        "recession_probability * 100 < 10 then \"0-10%\"\n",
        "when recession_probability * 100 < 25 then \"10-25%\"\n",
        "when recession_probability * 100 < 50 then \"25-50%\"\n",
        "else \"50%+\"\n",
        "end as Probability_Bucket FROM us_macroeconomics_tracker.gold.recession_predictions"
      ],
      "catalog": "us_macroeconomics_tracker",
      "schema": "gold"
    }
  ],
